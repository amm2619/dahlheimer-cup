rules_version = '2';

// Security rules for the Dahlheimer Cup site.
//
// Guests are anonymous (no login). Anyone can submit an RSVP, sign up for a
// chore, or post a putting score. But the sign-up *lists* — RSVPs and chore
// claims — are readable ONLY by signed-in hosts, so guests' names/emails/notes
// aren't exposed to everyone. The leaderboard and Wall of Fame stay public.
//
// Deploy with:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isHost() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
          'chris.foster@gmail.com',
          'amm2619@gmail.com',
          'brian.dahlheimer@gmail.com'
        ];
    }

    // Live leaderboard — anyone can read and post a score.
    match /scores/{id} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() <= 80
                    && request.resource.data.score is number;
      allow delete: if true;
      allow update: if false;
    }

    // Chore claims — anyone can sign up for a job, but only hosts can see who
    // signed up for what (the sign-up list is host-only, like RSVPs).
    match /claims/{choreId} {
      allow read: if isHost();
      allow write: if true;
    }

    // Wall of Fame photos — anyone can add or clear a photo.
    match /photos/{slotId} {
      allow read: if true;
      allow write: if true;
    }

    // RSVPs — guests may submit; only hosts may read or modify.
    match /rsvps/{id} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() <= 120
                    && request.resource.data.email is string;
      allow read, update, delete: if isHost();
    }
  }
}
