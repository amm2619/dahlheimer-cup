# Firebase web app config — copy to `.env` for local dev, or set these as
# GitHub repository secrets for the deploy workflow (see .github/workflows/deploy.yml).
# These values ship to the browser; they identify the project but are NOT a
# secret in the security sense. Access is controlled by Firestore rules (see firestore.rules).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# Optional — only needed if you use Firebase Storage / Analytics later.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Comma-separated Google accounts allowed to open the Host Dashboard.
VITE_HOST_EMAILS=chris.foster@gmail.com,amm2619@gmail.com,brian.dahlheimer@gmail.com

# Base path for the build. '/dahlheimer-cup/' for GitHub Pages project site,
# '/' for a custom domain or user/org Pages site.
VITE_BASE=/dahlheimer-cup/
